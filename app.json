{
  "expo": {
    "name": "spotify premium",
    "slug": "spotify",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/spotify.png",
    "scheme": "spotify-mobile",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/spotify.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/spotify.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/spotify.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}